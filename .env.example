# =============================================================================
# Job Search Automation Pipeline — Environment Configuration
# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — never commit real secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# n8n core
# ---------------------------------------------------------------------------
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# Generate a long random string (e.g. `openssl rand -hex 32`).
# Encrypts saved credentials inside n8n. Keep stable — losing it loses creds.
N8N_ENCRYPTION_KEY=replace-with-a-long-random-string

# Allow JS Code nodes to import any npm module (needed by this workflow).
NODE_FUNCTION_ALLOW_EXTERNAL=*
N8N_PERSONALIZATION_ENABLED=false
N8N_RESTRICT_ENVIRONMENT_VARIABLES_ACCESS=false
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# ---------------------------------------------------------------------------
# Timezone — used by n8n schedules and the daily digest
# ---------------------------------------------------------------------------
GENERIC_TIMEZONE=Europe/Paris
TZ=Europe/Paris

# ---------------------------------------------------------------------------
# LLM API keys (only used if you re-enable LLM scoring/tailoring nodes)
# Current default workflow uses regex-only scoring — these are optional.
# ---------------------------------------------------------------------------
# https://aistudio.google.com — 250 req/day free
GEMINI_API_KEY=
# https://console.groq.com — ~14,400 req/day free, OpenAI-compatible
GROQ_API_KEY=

# ---------------------------------------------------------------------------
# Job source API keys
# ---------------------------------------------------------------------------
# https://serpapi.com — 100 searches/month free
SERPAPI_KEY=
# https://developer.adzuna.com — 250 calls/month free
ADZUNA_APP_ID=
ADZUNA_KEY=
# https://francetravail.io — France only, effectively unlimited
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=
# https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch — 500 calls/month free
RAPIDAPI_KEY=

# ---------------------------------------------------------------------------
# Google integration — IDs of your own Sheet, Drive folder, and email
# ---------------------------------------------------------------------------
# Spreadsheet ID from the Google Sheets URL:
# docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=
# Drive folder ID where tailored PDFs land:
# drive.google.com/drive/folders/<THIS_PART>
GDRIVE_FOLDER_ID=
# Recipient for daily digest + high-priority alerts
NOTIFICATION_EMAIL=you@example.com

# ---------------------------------------------------------------------------
# Pre-made resume Drive links (one per role category)
# Upload one tailored PDF per category to Drive, then paste the share URL here.
# Categories are defined in workflow/n8n_job_automation_workflow.json — adjust
# both sides if you change them.
# ---------------------------------------------------------------------------
CV_LINK_COMPUTER_VISION=
CV_LINK_ML_ENGINEER=
CV_LINK_DATA_SCIENTIST=
CV_LINK_DATA_ANALYST=
CV_LINK_SOFTWARE_ENGINEER=

# ---------------------------------------------------------------------------
# Optional: cloud deployment with Caddy + DuckDNS
# Local Docker users can ignore this.
# ---------------------------------------------------------------------------
DOMAIN=your-subdomain.duckdns.org
